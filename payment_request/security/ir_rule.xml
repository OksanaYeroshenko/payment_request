<odoo>
    <record id="payment_request_portal_rule" model="ir.rule">
        <field name="name">Portal: Own Payment Requests</field>
        <field name="model_id" ref="model_payment_request"/>
        <field name="domain_force">['|', ('partner_id', '=', user.partner_id.id), ('requester_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('payment_request.group_payment_request_portal'))]"/>
    </record>
</odoo>
