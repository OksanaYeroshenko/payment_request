<odoo>
    <record id="action_move_in_invoice_to_check" model="ir.actions.act_window">
        <field name="name">Bills to Check</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type', '=', 'in_invoice'), ('checked', '=', False)]</field>
        <field name="context">{'default_move_type': 'in_invoice'}</field>
        <field name="search_view_id" ref="account.view_account_bill_filter"/>
    </record>

    <record id="account.menu_action_move_in_refund_type" model="ir.ui.menu">
        <field name="sequence">3</field>
    </record>
    <record id="account.menu_action_move_in_receipt_type" model="ir.ui.menu">
        <field name="sequence">4</field>
    </record>

    <menuitem id="menu_action_move_in_invoice_to_check"
              name="Bills to Check"
              parent="account.menu_finance_payables"
              action="action_move_in_invoice_to_check"
              sequence="2"/>
</odoo>
