<odoo>
    <data>
        <record id="view_move_form_inherit_payment_request" model="ir.ui.view">
            <field name="name">account.move.form.inherit.payment.request</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_open_payment_request"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-external-link"
                            string="Payment Request"
                            invisible="not payment_request_id"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
