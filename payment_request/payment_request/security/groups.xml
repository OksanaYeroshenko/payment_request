<odoo>

    <record id="module_category_payment_request" model="ir.module.category">
        <field name="name">Payment Requests</field>
        <field name="description">Access rights for payment request features.</field>
        <field name="sequence">45</field>
    </record>

    <record id="group_payment_request_operation_manager" model="res.groups">
        <field name="name">Operation Manager</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Users in this group are auto-subscribed to Payment Requests and receive chatter notifications.</field>
    </record>

    <record id="group_payment_request_portal" model="res.groups">
        <field name="name">Payment Request Portal</field>
        <field name="category_id" ref="payment_request.module_category_payment_request"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        <field name="comment">Portal users in this group can access Payment Requests menu and model.</field>
    </record>

</odoo>
